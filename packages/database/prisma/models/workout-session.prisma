model WorkoutSession {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")

  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId Int      @map("exercise_id")

  processingStatus SessionStatus @default(PENDING) @map("processing_status")
  notes            String?
  performedAt      DateTime      @default(now()) @map("performed_at")

  videoDurationSec Decimal? @map("video_duration_sec") @db.Decimal(6, 2)
  videoFps         Decimal? @map("video_fps") @db.Decimal(6, 2)
  videoWidth       Int?     @map("video_width")
  videoHeight      Int?     @map("video_height")
  videoSizeBytes   BigInt?  @map("video_size_bytes")

  processingStartedAt  DateTime? @map("processing_started_at")
  processingFinishedAt DateTime? @map("processing_finished_at")
  failureReason        String?   @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  analysisResult AnalysisResult?
  userMilestones UserMilestone[]

  @@index([userId, performedAt(sort: Desc)], map: "idx_sessions_user_performed_at_desc")
  @@index([userId, exerciseId, performedAt(sort: Desc)], map: "idx_sessions_user_exercise_performed_at_desc")
  @@index([processingStatus], map: "idx_sessions_processing_status")
  @@map("workout_sessions")
}
